<Window x:Class="ClaudeUsageMonitor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - Claude Usage Monitor" 
        Height="400" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF2D2D30">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Session Key -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Session Key" Foreground="White" Margin="0,0,0,4"/>
            <TextBox x:Name="SessionKeyTextBox" 
                     Height="24"
                     Background="#FF3F3F46"
                     Foreground="White"
                     BorderBrush="#FF5A5A5A"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="Paste from Clipboard" 
                        Click="PasteSessionKey_Click"
                        Padding="8,4"
                        Background="#FF3F3F46"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,4,0"/>
                <Button Content="Validate" 
                        Click="ValidateSessionKey_Click"
                        Padding="8,4"
                        Background="#FF3F3F46"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
            <TextBlock x:Name="ValidationStatus" 
                       Foreground="#FF808080" 
                       FontSize="10" 
                       Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Organization -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Organization" Foreground="White" Margin="0,0,0,4"/>
            <ComboBox x:Name="OrganizationComboBox"
                      Height="24"
                      Background="#FF3F3F46"
                      Foreground="White"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Uuid"/>
            <Button Content="Refresh Organizations" 
                    Click="RefreshOrganizations_Click"
                    Padding="8,4"
                    Background="#FF3F3F46"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,4,0,0"
                    HorizontalAlignment="Left"/>
        </StackPanel>
        
        <!-- Refresh Interval -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="Refresh Interval" Foreground="White" Margin="0,0,0,4"/>
            <ComboBox x:Name="IntervalComboBox"
                      Height="24"
                      Background="#FF3F3F46"
                      Foreground="White"
                      SelectedIndex="1">
                <ComboBoxItem Content="15 seconds" Tag="15"/>
                <ComboBoxItem Content="30 seconds" Tag="30"/>
                <ComboBoxItem Content="1 minute" Tag="60"/>
                <ComboBoxItem Content="5 minutes" Tag="300"/>
            </ComboBox>
        </StackPanel>
        
        <!-- Options -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <CheckBox x:Name="StartWithWindowsCheckBox" 
                      Content="Start with Windows"
                      Foreground="White"/>
            <CheckBox x:Name="NotificationsCheckBox" 
                      Content="Show notifications at 80%/90%"
                      Foreground="White"
                      Margin="0,4,0,0"
                      IsChecked="True"/>
        </StackPanel>
        
        <!-- How to get session key -->
        <Border Grid.Row="4" Background="#FF252526" CornerRadius="4" Padding="8" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="How to get Session Key:" Foreground="#FFB0B0B0" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap" Foreground="#FF808080" FontSize="11" Margin="0,4,0,0">
                    1. Go to claude.ai and log in
                    2. Open DevTools (F12)
                    3. Go to Application → Cookies
                    4. Find "sessionKey" and copy its value
                </TextBlock>
            </StackPanel>
        </Border>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" 
                    Click="Save_Click"
                    Padding="16,6"
                    Background="#FF0078D4"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel" 
                    Click="Cancel_Click"
                    Padding="16,6"
                    Background="#FF3F3F46"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
