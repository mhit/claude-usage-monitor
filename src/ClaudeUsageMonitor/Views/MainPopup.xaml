<UserControl x:Class="ClaudeUsageMonitor.Views.MainPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ClaudeUsageMonitor.ViewModels"
             Width="280" Background="#FF2D2D30">
    
    <Border BorderBrush="#FF3F3F46" BorderThickness="1" CornerRadius="4">
        <StackPanel Margin="12">
            <!-- Header -->
            <TextBlock Text="Claude Usage Monitor" 
                       Style="{StaticResource HeaderText}"
                       Foreground="White" 
                       Margin="0,0,0,12"/>
            
            <!-- Session Usage -->
            <Border Background="#FF3F3F46" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="📊 Session (5h window)" 
                               Foreground="#FFB0B0B0" 
                               FontSize="11"/>
                    
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Progress Bar -->
                        <Border Grid.Column="0" 
                                Background="#FF1E1E1E" 
                                CornerRadius="3" 
                                Height="20"
                                Margin="0,0,8,0">
                            <Border Background="{Binding CurrentLevel, Converter={StaticResource LevelToBrushConverter}}"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="{Binding Utilization, Converter={StaticResource PercentToWidthConverter}}"/>
                        </Border>
                        
                        <!-- Percentage -->
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding UtilizationText}"
                                   Style="{StaticResource ValueText}"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Reset time -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Resets at: " Foreground="#FF808080"/>
                        <TextBlock Text="{Binding ResetTimeText}" Foreground="#FFB0B0B0"/>
                        <TextBlock Text=" (" Foreground="#FF808080"/>
                        <TextBlock Text="{Binding TimeUntilResetText}" Foreground="#FF808080"/>
                        <TextBlock Text=")" Foreground="#FF808080"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Status Bar -->
            <Border Background="#FF252526" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Plan" Foreground="#FF808080" FontSize="10"/>
                        <TextBlock Text="{Binding PlanText}" Foreground="White"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Last Update" Foreground="#FF808080" FontSize="10"/>
                        <TextBlock Text="{Binding LastUpdateText}" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Status -->
            <TextBlock Text="{Binding StatusText}" 
                       Foreground="#FF808080" 
                       FontSize="10"
                       Margin="0,0,0,8"/>
            
            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="⚙ Settings" 
                        Command="{Binding OpenSettingsCommand}"
                        Margin="0,0,4,0"
                        Padding="8,4"
                        Background="#FF3F3F46"
                        Foreground="White"
                        BorderThickness="0"/>
                
                <Button Content="🔄 Refresh" 
                        Command="{Binding RefreshCommand}"
                        Margin="0,0,4,0"
                        Padding="8,4"
                        Background="#FF3F3F46"
                        Foreground="White"
                        BorderThickness="0"/>
                
                <Button Content="✕ Quit" 
                        Command="{Binding QuitCommand}"
                        Padding="8,4"
                        Background="#FF3F3F46"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
