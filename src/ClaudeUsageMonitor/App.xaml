<Application x:Class="ClaudeUsageMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Colors -->
        <Color x:Key="SafeColor">#4CAF50</Color>
        <Color x:Key="ModerateColor">#FF9800</Color>
        <Color x:Key="CriticalColor">#F44336</Color>
        
        <SolidColorBrush x:Key="SafeBrush" Color="{StaticResource SafeColor}"/>
        <SolidColorBrush x:Key="ModerateBrush" Color="{StaticResource ModerateColor}"/>
        <SolidColorBrush x:Key="CriticalBrush" Color="{StaticResource CriticalColor}"/>
        
        <!-- Base styles -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Application.Resources>
</Application>
